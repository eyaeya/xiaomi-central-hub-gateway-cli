{
  "name": "@eyaeya/xgg-cli",
  "version": "0.1.4",
  "description": "Command-line tool for operating Xiaomi Gateway Geek Edition automations",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "bin": {
    "xgg": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/program.d.ts",
      "import": "./dist/program.js",
      "default": "./dist/program.js"
    }
  },
  "files": ["dist", "LICENSE", "README.md", "skills"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eyaeya/xiaomi-central-hub-gateway-cli.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/eyaeya/xiaomi-central-hub-gateway-cli#readme",
  "bugs": {
    "url": "https://github.com/eyaeya/xiaomi-central-hub-gateway-cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../scripts/clean-dist.mjs && tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@eyaeya/xgg-core": "workspace:^",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "string-width": "^4.2.3"
  }
}
